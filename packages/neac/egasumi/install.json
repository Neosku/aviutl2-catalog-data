{
  "installation": {
    "source": {
      "type": "githubRelease",
      "owner": "nea-c",
      "repo": "aviutl2_script_Egasumi",
      "pattern": "^Egasumi\\.zip$"
    },
    "installSteps": [
      {
        "action": "download"
      },
      {
        "action": "extract"
      },
      {
        "action": "copy",
        "from": "{tmp}/エ霞.obj2",
        "to": "{scriptsDir}"
      }
    ],
    "uninstallSteps": [
      {
        "action": "delete",
        "path": "{scriptsDir}/エ霞.obj2"
      }
    ]
  }
}
