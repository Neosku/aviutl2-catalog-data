{
  "installation": {
    "source": {
      "type": "githubRelease",
      "owner": "nea-c",
      "repo": "aviutl2_script_ScreenAspect",
      "pattern": "^ScreenAspect\\.zip$"
    },
    "installSteps": [
      {
        "action": "download"
      },
      {
        "action": "extract"
      },
      {
        "action": "copy",
        "from": "{tmp}/画面アスペクト.obj2",
        "to": "{scriptsDir}"
      }
    ],
    "uninstallSteps": [
      {
        "action": "delete",
        "path": "{scriptsDir}/画面アスペクト.obj2"
      }
    ]
  }
}
