{
  "installation": {
    "source": {
      "type": "githubRelease",
      "owner": "cycloawaodorin",
      "repo": "resize_ks",
      "pattern": "^resize_ks\\..*\\.zip$"
    },
    "installSteps": [
      {
        "action": "download"
      },
      {
        "action": "extract"
      },
      {
        "action": "copy",
        "from": "{tmp}/resize_ks.auf2",
        "to": "{pluginsDir}"
      }
    ],
    "uninstallSteps": [
      {
        "action": "delete",
        "path": "{pluginsDir}/resize_ks.auf2"
      }
    ]
  }
}
