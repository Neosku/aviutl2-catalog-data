{
  "installation": {
    "source": {
      "type": "githubRelease",
      "owner": "cycloawaodorin",
      "repo": "ksa",
      "pattern": "^ksa\\..*\\.au2pkg\\.zip$"
    },
    "installSteps": [
      {
        "action": "download"
      },
      {
        "action": "extract"
      },
      {
        "action": "copy",
        "from": "{tmp}/Script",
        "to": "{scriptsDir}"
      }
    ],
    "uninstallSteps": [
      {
        "action": "delete",
        "path": "{scriptsDir}/KSA"
      }
    ]
  }
}
