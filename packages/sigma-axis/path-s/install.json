{
  "installation": {
    "source": {
      "type": "githubRelease",
      "owner": "sigma-axis",
      "repo": "aviutl2_script_Path_S",
      "pattern": "^aviutl2_script_Path_S.*\\.zip$"
    },
    "installSteps": [
      {
        "action": "download"
      },
      {
        "action": "extract"
      },
      {
        "action": "copy",
        "from": "{tmp}/Script/@Path_S.anm2",
        "to": "{scriptsDir}"
      },
      {
        "action": "copy",
        "from": "{tmp}/Script/@Path_S.obj2",
        "to": "{scriptsDir}"
      },
      {
        "action": "copy",
        "from": "{tmp}/Script/Path_S.lua",
        "to": "{scriptsDir}"
      },
      {
        "action": "copy",
        "from": "{tmp}/Script/Path_S/LICENSE",
        "to": "{scriptsDir}/Path_S"
      },
      {
        "action": "copy",
        "from": "{tmp}/Script/Path_S/README.md",
        "to": "{scriptsDir}/Path_S"
      }
    ],
    "uninstallSteps": [
      {
        "action": "delete",
        "path": "{scriptsDir}/@Path_S.anm2"
      },
      {
        "action": "delete",
        "path": "{scriptsDir}/@Path_S.obj2"
      },
      {
        "action": "delete",
        "path": "{scriptsDir}/Path_S.lua"
      },
      {
        "action": "delete",
        "path": "{scriptsDir}/Path_S/LICENSE"
      },
      {
        "action": "delete",
        "path": "{scriptsDir}/Path_S/README.md"
      }
    ]
  }
}
