{
  "installation": {
    "source": {
      "type": "githubRelease",
      "owner": "sigma-axis",
      "repo": "aviutl2_script_Histogram_S",
      "pattern": "^aviutl2_script_Histogram_S.*\\.zip$"
    },
    "installSteps": [
      {
        "action": "download"
      },
      {
        "action": "extract"
      },
      {
        "action": "copy",
        "from": "{tmp}/Histogram_S.obj2",
        "to": "{scriptsDir}"
      }
    ],
    "uninstallSteps": [
      {
        "action": "delete",
        "path": "{scriptsDir}/Histogram_S.obj2"
      }
    ]
  }
}
