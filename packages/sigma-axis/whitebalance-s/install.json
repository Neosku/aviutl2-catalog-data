{
  "installation": {
    "source": {
      "type": "githubRelease",
      "owner": "sigma-axis",
      "repo": "aviutl2_script_WhiteBalance_S",
      "pattern": "^aviutl2_script_WhiteBalance_S.*\\.zip$"
    },
    "installSteps": [
      {
        "action": "download"
      },
      {
        "action": "extract"
      },
      {
        "action": "copy",
        "from": "{tmp}/Script/@WhiteBalance_S.anm2",
        "to": "{scriptsDir}"
      },
      {
        "action": "copy",
        "from": "{tmp}/Script/WhiteBalance_S/LICENSE",
        "to": "{scriptsDir}/WhiteBalance_S"
      },
      {
        "action": "copy",
        "from": "{tmp}/Script/WhiteBalance_S/README.md",
        "to": "{scriptsDir}/WhiteBalance_S"
      }
    ],
    "uninstallSteps": [
      {
        "action": "delete",
        "path": "{scriptsDir}/@WhiteBalance_S.anm2"
      },
      {
        "action": "delete",
        "path": "{scriptsDir}/WhiteBalance_S/LICENSE"
      },
      {
        "action": "delete",
        "path": "{scriptsDir}/WhiteBalance_S/README.md"
      }
    ]
  }
}
