{
  "relations": {
    "requires": [
      "sigma-axis.border-s"
    ]
  },
  "installation": {
    "source": {
      "type": "githubRelease",
      "owner": "sigma-axis",
      "repo": "aviutl2_script_Region_S",
      "pattern": "^aviutl2_script_Region_S.*\\.zip$"
    },
    "installSteps": [
      {
        "action": "download"
      },
      {
        "action": "extract"
      },
      {
        "action": "copy",
        "from": "{tmp}/Script/@Region_S.anm2",
        "to": "{scriptsDir}"
      },
      {
        "action": "copy",
        "from": "{tmp}/Script/Region_S.lua",
        "to": "{scriptsDir}"
      },
      {
        "action": "copy",
        "from": "{tmp}/Script/Region_S/LICENSE",
        "to": "{scriptsDir}/Region_S"
      },
      {
        "action": "copy",
        "from": "{tmp}/Script/Region_S/README.md",
        "to": "{scriptsDir}/Region_S"
      }
    ],
    "uninstallSteps": [
      {
        "action": "delete",
        "path": "{scriptsDir}/@Region_S.anm2"
      },
      {
        "action": "delete",
        "path": "{scriptsDir}/Region_S.lua"
      },
      {
        "action": "delete",
        "path": "{scriptsDir}/Region_S/"
      }
    ]
  }
}
