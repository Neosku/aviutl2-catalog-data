{
  "installation": {
    "source": {
      "type": "githubRelease",
      "owner": "fu-majime",
      "repo": "AviUtl2_PolygonMorph_F",
      "pattern": "^PolygonMorph_F.*\\.au2pkg\\.zip$"
    },
    "installSteps": [
      {
        "action": "download"
      },
      {
        "action": "extract"
      },
      {
        "action": "copy",
        "from": "{tmp}/Script/多角形モーフ_F.obj2",
        "to": "{scriptsDir}"
      }
    ],
    "uninstallSteps": [
      {
        "action": "delete",
        "path": "{scriptsDir}/多角形モーフ_F.obj2"
      }
    ]
  }
}
