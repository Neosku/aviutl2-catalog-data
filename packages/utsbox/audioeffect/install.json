{
  "installation": {
    "source": {
      "type": "directUrl",
      "url": "https://www.utsbox.com/wp-content/uploads/2025/10/UtsboxAudioEffectForAviUtl2.zip"
    },
    "installSteps": [
      {
        "action": "download"
      },
      {
        "action": "extract"
      },
      {
        "action": "copy",
        "from": "{tmp}/UtsboxAudioEffectForAviUtl2",
        "to": "{pluginsDir}/UtsboxAudioEffectForAviUtl2"
      }
    ],
    "uninstallSteps": [
      {
        "action": "delete",
        "path": "{pluginsDir}/UtsboxAudioEffectForAviUtl2"
      }
    ]
  }
}
