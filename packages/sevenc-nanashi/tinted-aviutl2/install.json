{
  "installation": {
    "source": {
      "type": "githubRelease",
      "owner": "sevenc-nanashi",
      "repo": "tinted-aviutl2",
      "pattern": "^.*tinted-aviutl2-v[^/]+\\.au2pkg\\.zip$"
    },
    "installSteps": [
      {
        "action": "download"
      },
      {
        "action": "extract"
      },
      {
        "action": "copy",
        "from": "{tmp}/Language/English.tinted-aviutl2.aul2",
        "to": "{dataDir}/Language"
      },
      {
        "action": "copy",
        "from": "{tmp}/Plugin/tinted-aviutl2.aux2",
        "to": "{pluginsDir}"
      }
    ],
    "uninstallSteps": [
      {
        "action": "delete",
        "path": "{pluginsDir}/tinted-aviutl2.aux2"
      },
      {
        "action": "delete",
        "path": "{dataDir}/Language/English.tinted-aviutl2.aul2"
      }
    ]
  }
}
