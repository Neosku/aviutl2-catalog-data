{
  "installation": {
    "source": {
      "type": "githubRelease",
      "owner": "sevenc-nanashi",
      "repo": "open_project_directory.aux2",
      "pattern": "^.*open_project_directory-v[^/]+\\.au2pkg\\.zip$"
    },
    "installSteps": [
      {
        "action": "download"
      },
      {
        "action": "extract"
      },
      {
        "action": "copy",
        "from": "{tmp}/Language/English.open_project_directory.aul2",
        "to": "{dataDir}/Language"
      },
      {
        "action": "copy",
        "from": "{tmp}/Plugin/open_project_directory.aux2",
        "to": "{pluginsDir}"
      }
    ],
    "uninstallSteps": [
      {
        "action": "delete",
        "path": "{pluginsDir}/open_project_directory.aux2"
      },
      {
        "action": "delete",
        "path": "{dataDir}/Language/English.open_project_directory.aul2"
      }
    ]
  }
}
