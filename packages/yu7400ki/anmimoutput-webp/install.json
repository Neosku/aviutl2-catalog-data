{
  "installation": {
    "source": {
      "type": "directUrl",
      "url": "https://github.com/yu7400ki/aviutl2-animated-image-output/releases/download/webp-v1.1.2/webp_output.auo2"
    },
    "installSteps": [
      {
        "action": "download"
      },
      {
        "action": "copy",
        "from": "{tmp}/webp_output.auo2",
        "to": "{pluginsDir}"
      }
    ],
    "uninstallSteps": [
      {
        "action": "delete",
        "path": "{pluginsDir}/webp_output.auo2"
      },
      {
        "action": "delete",
        "path": "{pluginsDir}/webp_output.ini"
      }
    ]
  }
}
