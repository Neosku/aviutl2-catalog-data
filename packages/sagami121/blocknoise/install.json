{
  "installation": {
    "source": {
      "type": "githubRelease",
      "owner": "sagami121",
      "repo": "Aviutl2-BlockNoise",
      "pattern": "^BlockNoise.*\\.zip$"
    },
    "installSteps": [
      {
        "action": "download"
      },
      {
        "action": "extract"
      },
      {
        "action": "copy",
        "from": "{tmp}/BlockNoise.anm2",
        "to": "{scriptsDir}"
      }
    ],
    "uninstallSteps": [
      {
        "action": "delete",
        "path": "{scriptsDir}/BlockNoise.anm2"
      }
    ]
  }
}
