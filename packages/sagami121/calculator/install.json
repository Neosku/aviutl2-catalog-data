{
  "installation": {
    "source": {
      "type": "githubRelease",
      "owner": "sagami121",
      "repo": "Aviutl2-Calculator",
      "pattern": "^aviutl2_calc.*\\.zip$"
    },
    "installSteps": [
      {
        "action": "download"
      },
      {
        "action": "extract"
      },
      {
        "action": "copy",
        "from": "{tmp}/aviutl2_calc.aux2",
        "to": "{pluginsDir}"
      }
    ],
    "uninstallSteps": [
      {
        "action": "delete",
        "path": "{pluginsDir}/aviutl2_calc.aux2"
      }
    ]
  }
}
