{
  "installation": {
    "source": {
      "type": "githubRelease",
      "owner": "osakana4242",
      "repo": "aviutl2-gif-bayer-dither-output",
      "pattern": "^GifBayerDitherOutput-v(.+).zip$"
    },
    "installSteps": [
      {
        "action": "download"
      },
      {
        "action": "extract"
      },
      {
        "action": "copy",
        "from": "{tmp}/GifBayerDitherOutput.auo2",
        "to": "{pluginsDir}"
      }
    ],
    "uninstallSteps": [
      {
        "action": "delete",
        "path": "{pluginsDir}/GifBayerDitherOutput.auo2"
      }
    ]
  }
}
