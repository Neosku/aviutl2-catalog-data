{
  "installation": {
    "source": {
      "type": "githubRelease",
      "owner": "seilor0",
      "repo": "roundedPolygon_sl",
      "pattern": "^roundedPolygon_sl\\.zip$"
    },
    "installSteps": [
      {
        "action": "download"
      },
      {
        "action": "extract"
      },
      {
        "action": "copy",
        "from": "{tmp}/角丸正多角形_sl.obj2",
        "to": "{scriptsDir}"
      }
    ],
    "uninstallSteps": [
      {
        "action": "delete",
        "path": "{scriptsDir}/角丸正多角形_sl.obj2"
      }
    ]
  }
}
