{
  "installation": {
    "source": {
      "type": "directUrl",
      "url": "https://raw.githubusercontent.com/teruyoshii/Teruyoshi_AviUtl2_Scripts/refs/heads/main/段階グラデーション.anm2"
    },
    "installSteps": [
      {
        "action": "download"
      },
      {
        "action": "copy",
        "from": "{tmp}/段階グラデーション.anm2",
        "to": "{scriptsDir}"
      }
    ],
    "uninstallSteps": [
      {
        "action": "delete",
        "path": "{scriptsDir}/段階グラデーション.anm2"
      }
    ]
  }
}
