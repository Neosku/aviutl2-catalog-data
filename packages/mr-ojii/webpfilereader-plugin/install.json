{
  "installation": {
    "source": {
      "type": "githubRelease",
      "owner": "Mr-Ojii",
      "repo": "AviUtl2-WebPFileReader-Plugin",
      "pattern": "^webpinput\\.zip$"
    },
    "installSteps": [
      {
        "action": "download"
      },
      {
        "action": "extract"
      },
      {
        "action": "copy",
        "from": "{tmp}/webpinput.aui2",
        "to": "{pluginsDir}"
      }
    ],
    "uninstallSteps": [
      {
        "action": "delete",
        "path": "{pluginsDir}/webpinput.aui2"
      }
    ]
  }
}
