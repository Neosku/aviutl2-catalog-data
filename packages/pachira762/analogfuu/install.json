{
  "installation": {
    "source": {
      "type": "githubRelease",
      "owner": "Pachira762",
      "repo": "AnalogFuu",
      "pattern": "^AnalogFuu_.*\\.zip$"
    },
    "installSteps": [
      {
        "action": "download"
      },
      {
        "action": "extract"
      },
      {
        "action": "copy",
        "from": "{tmp}/AnalogFuu/AnalogFuu.auf2",
        "to": "{pluginsDir}"
      }
    ],
    "uninstallSteps": [
      {
        "action": "delete",
        "path": "{pluginsDir}/AnalogFuu.auf2"
      }
    ]
  }
}
