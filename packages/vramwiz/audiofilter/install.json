{
  "installation": {
    "source": {
      "type": "githubRelease",
      "owner": "vramwiz",
      "repo": "Aul2AudioFilter",
      "pattern": "^Aul2AudioFilter\\.zip$"
    },
    "installSteps": [
      {
        "action": "download"
      },
      {
        "action": "extract"
      },
      {
        "action": "copy",
        "from": "{tmp}/Aul2AudioFilter/Aul2AudioFilter.auf2",
        "to": "{pluginsDir}/Aul2AudioFilter"
      },
      {
        "action": "copy",
        "from": "{tmp}/Aul2AudioFilter/Aul2AudioMonitor.aux2",
        "to": "{pluginsDir}/Aul2AudioFilter"
      },
      {
        "action": "copy",
        "from": "{tmp}/Aul2AudioFilter/Aul2AudioBaseInput.aui2",
        "to": "{pluginsDir}/Aul2AudioFilter"
      },
      {
        "action": "copy",
        "from": "{tmp}/Aul2AudioFilter/Aul2AudioView.auf2",
        "to": "{pluginsDir}/Aul2AudioFilter"
      },
      {
        "action": "copy",
        "from": "{tmp}/Aul2AudioFilter/Aul2AudioController.aux2",
        "to": "{pluginsDir}/Aul2AudioFilter"
      }
    ],
    "uninstallSteps": [
      {
        "action": "delete",
        "path": "{pluginsDir}/Aul2AudioFilter/Aul2AudioFilter.auf2"
      },
      {
        "action": "delete",
        "path": "{pluginsDir}/Aul2AudioFilter/Aul2AudioMonitor.aux2"
      },
      {
        "action": "delete",
        "path": "{pluginsDir}/Aul2AudioFilter/Aul2AudioBaseInput.aui2"
      },
      {
        "action": "delete",
        "path": "{pluginsDir}/Aul2AudioFilter/Aul2AudioView.auf2"
      },
      {
        "action": "delete",
        "path": "{pluginsDir}/Aul2AudioFilter/Aul2AudioController.aux2"
      }
    ]
  }
}
