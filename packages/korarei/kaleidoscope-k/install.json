{
  "installation": {
    "source": {
      "type": "githubRelease",
      "owner": "korarei",
      "repo": "AviUtl2_Kaleidoscope_K_Script",
      "pattern": "^Kaleidoscope_K.*\\.zip$"
    },
    "installSteps": [
      {
        "action": "download"
      },
      {
        "action": "extract"
      },
      {
        "action": "copy",
        "from": "{tmp}/Kaleidoscope_K/Kaleidoscope_K.anm2",
        "to": "{scriptsDir}"
      }
    ],
    "uninstallSteps": [
      {
        "action": "delete",
        "path": "{scriptsDir}/Kaleidoscope_K.anm2"
      }
    ]
  }
}
