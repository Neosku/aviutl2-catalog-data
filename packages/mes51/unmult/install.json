{
  "installation": {
    "source": {
      "type": "githubRelease",
      "owner": "mes51",
      "repo": "AVIUtl2_Unmult",
      "pattern": ".*Unmult_.*\\.zip"
    },
    "installSteps": [
      {
        "action": "download"
      },
      {
        "action": "extract"
      },
      {
        "action": "copy",
        "from": "{tmp}/AVIUtl2_Unmult/Unmult.anm2",
        "to": "{scriptsDir}"
      }
    ],
    "uninstallSteps": [
      {
        "action": "delete",
        "path": "{scriptsDir}/Unmult.anm2"
      }
    ]
  }
}
