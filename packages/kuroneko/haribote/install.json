{
  "installation": {
    "source": {
      "type": "githubRelease",
      "owner": "rokujyushi",
      "repo": "Haribote",
      "pattern": "HariboteReader\\.zip"
    },
    "installSteps": [
      {
        "action": "download"
      },
      {
        "action": "extract"
      },
      {
        "action": "copy",
        "from": "{tmp}\\HariboteReader.aui2",
        "to": "{pluginsDir}"
      }
    ],
    "uninstallSteps": [
      {
        "action": "delete",
        "path": "{pluginsDir}\\HariboteReader.aui2"
      }
    ]
  }
}
