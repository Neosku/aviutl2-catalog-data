{
  "installation": {
    "source": {
      "type": "githubRelease",
      "owner": "hebiiro",
      "repo": "al2_slimming",
      "pattern": "^al2_slimming.*\\.zip$"
    },
    "installSteps": [
      {
        "action": "delete",
        "path": "{pluginsDir}/al2_jd.aui2"
      },
      {
        "action": "delete",
        "path": "{pluginsDir}/DarkenWindow.aul"
      },
      {
        "action": "delete",
        "path": "{pluginsDir}/al2/assets/al2_jd.json"
      },
      {
        "action": "download"
      },
      {
        "action": "extract"
      },
      {
        "action": "copy",
        "from": "{tmp}/Plugin",
        "to": "{pluginsDir}"
      }
    ],
    "uninstallSteps": [
      {
        "action": "delete",
        "path": "{pluginsDir}/al2/al2_slimming.aui2"
      },
      {
        "action": "delete",
        "path": "{dataDir}/Language/Template/al2_slimming.aul2"
      }
    ]
  }
}
