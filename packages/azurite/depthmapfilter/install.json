{
  "installation": {
    "source": {
      "type": "githubRelease",
      "owner": "azurite581",
      "repo": "AviUtl2-DepthMapFilter",
      "pattern": "^DepthMapFilter-v.*\\.au2pkg\\.zip$"
    },
    "installSteps": [
      {
        "action": "download"
      },
      {
        "action": "extract"
      },
      {
        "action": "copy",
        "from": "{tmp}/Plugin/DepthMapFilter/depth_anything_v2_vits.onnx",
        "to": "{pluginsDir}/DepthMapFilter"
      },
      {
        "action": "copy",
        "from": "{tmp}/Plugin/DepthMapFilter/DepthMapFilter.auf2",
        "to": "{pluginsDir}/DepthMapFilter"
      },
      {
        "action": "copy",
        "from": "{tmp}/Plugin/DepthMapFilter/onnxruntime.dll",
        "to": "{pluginsDir}/DepthMapFilter"
      }
    ],
    "uninstallSteps": [
      {
        "action": "delete",
        "path": "{pluginsDir}/DepthMapFilter/depth_anything_v2_vits.onnx"
      },
      {
        "action": "delete",
        "path": "{pluginsDir}/DepthMapFilter/DepthMapFilter.auf2"
      },
      {
        "action": "delete",
        "path": "{pluginsDir}/DepthMapFilter/onnxruntime.dll"
      }
    ]
  }
}
