{
  "installation": {
    "source": {
      "type": "githubRelease",
      "owner": "azurite581",
      "repo": "AviUtl2-PointZoom",
      "pattern": "^PointZoom.*\\.zip$"
    },
    "installSteps": [
      {
        "action": "download"
      },
      {
        "action": "extract"
      },
      {
        "action": "copy",
        "from": "{tmp}/Script/ポイントズーム.anm2",
        "to": "{scriptsDir}"
      }
    ],
    "uninstallSteps": [
      {
        "action": "delete",
        "path": "{scriptsDir}/ポイントズーム.anm2"
      }
    ]
  }
}
