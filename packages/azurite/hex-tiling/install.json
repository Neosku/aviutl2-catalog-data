{
  "installation": {
    "source": {
      "type": "githubRelease",
      "owner": "azurite581",
      "repo": "AviUtl2-Hex-Tiling",
      "pattern": "^.*Hex-Tiling.*\\.au2pkg\\.zip$"
    },
    "installSteps": [
      {
        "action": "download"
      },
      {
        "action": "extract"
      },
      {
        "action": "copy",
        "from": "{tmp}/Script/Hex-Tiling.anm2",
        "to": "{scriptsDir}"
      }
    ],
    "uninstallSteps": [
      {
        "action": "delete",
        "path": "{scriptsDir}/Hex-Tiling.anm2"
      },
      {
        "action": "delete",
        "path": "{dataDir}/Language/English.Hex-Tiling.aul2"
      }
    ]
  }
}
